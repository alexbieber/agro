# Copy to .env.local and fill in before going live.
# See README "Before going live" for details.

# Required: WhatsApp number for orders/support (no + or spaces, e.g. 919876543210)
NEXT_PUBLIC_WHATSAPP_NUMBER=919XXXXXXXXX

# Site identity
NEXT_PUBLIC_SITE_NAME=Nandi Agrotech
NEXT_PUBLIC_SITE_URL=https://nandiagrotech.com
NEXT_PUBLIC_SITE_TAGLINE=Trusted Agriculture Solutions for Indian Farmers

# Optional: Landline/support number shown on bulk orders (e.g. +91-80-XXXX-XXXX)
# Leave unset to show "Need help? Reach us on WhatsApp" instead.
# NEXT_PUBLIC_SUPPORT_PHONE=+91-80-XXXX-XXXX
